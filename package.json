{
  "name": "twilight-garden",
  "version": "1.0.0",
  "description": "A rich Discord RPG bot — Twilight Garden",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "ts-node src/database/migrate.ts",
    "lint": "eslint src --ext .ts",
    "register": "ts-node --transpile-only src/deploy-commands.ts",
    "push": "drizzle-kit push:pg"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "drizzle-orm": "^0.30.10",
    "pg": "^8.11.5",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.21.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
